<Window x:Class="PinMap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:local="clr-namespace:PinMap.UserControls"
        xmlns:vm="clr-namespace:PinMap.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PinMap" Height="1200" Width="1200">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="1000"/>
            <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="1000"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Button Content="Test" Command="{Binding TestCommand}" Margin="20"/>
        </Grid>
        
        <Grid Grid.Column="1" Grid.Row="1">
            <local:PointDisplayControl
            Points="{Binding Points}"
            ChannelColors="{Binding ChannelColors}"/>
        </Grid>

        
    </Grid>
</Window>